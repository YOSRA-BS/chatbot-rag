# =============================================================================
# .env.example — Variables d'environnement pour la pipeline CI/CD
# 
# ⚠️ IMPORTANT : 
#   - Ce fichier est une TEMPLATE
#   - NE PAS committer de .env avec secrets réels
#   - Utilisez GitLab CI/CD Variables pour les secrets
#   - Voir GUIDE_GITLAB.md section "Configuration initiale"
# =============================================================================

# ── GitLab Registry Configuration ──────────────────────────────────────────
# ⭐ Recommandé : Utiliser GitLab Container Registry (intégré à GitLab)
# Les variables CI_REGISTRY_USER et CI_REGISTRY_PASSWORD sont fournies automatiquement
# par GitLab lors de l'exécution de la pipeline. Pas besoin de les définir manuellement.
REGISTRY="registry.gitlab.com"
IMAGE_NAME="registry.gitlab.com/votre-username/mon-chatbot"
# CI_REGISTRY_USER et CI_REGISTRY_PASSWORD sont automatiques via GitLab

# ── MLflow Configuration ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI="http://localhost:5000"              # Local dev
# MLFLOW_TRACKING_URI="http://mlflow-server:5000"        # Production
# MLFLOW_TRACKING_URI="s3://my-bucket/mlruns"            # S3 backend
MLFLOW_EXPERIMENT_NAME="RAG-Evaluation"

# ── Ollama Configuration ──────────────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
OLLAMA_TIMEOUT=300

# ── Ragas Evaluation Configuration ────────────────────────────────────────
RAGAS_BATCH_SIZE=10
RAGAS_TIMEOUT=60                    # Seconds per question
QUALITY_THRESHOLD=0.5               # Minimum acceptable score

# ── Testing Configuration ────────────────────────────────────────────────
PYTEST_TIMEOUT=300
COVERAGE_THRESHOLD=70               # Minimum coverage %

# ── Deployment Configuration ─────────────────────────────────────────────
STAGING_DEPLOY_URL="https://staging.example.com"
PRODUCTION_DEPLOY_URL="https://api.example.com"
DEPLOYMENT_TIMEOUT=600

# ── Security Configuration ──────────────────────────────────────────────
# Enable/disable security scans
ENABLE_BANDIT=true
ENABLE_SAFETY=true
ENABLE_PIP_AUDIT=true

# ── Logging Configuration ────────────────────────────────────────────────
LOG_LEVEL="INFO"
LOG_FILE="/app/logs/pipeline.log"

# ── Python Configuration ────────────────────────────────────────────────
PYTHON_VERSION="3.11"
PIP_NO_CACHE_DIR="1"
PYTHON_DONT_WRITE_BYTECODE="1"

# ── Torch Configuration ──────────────────────────────────────────────────
TORCH_VERSION="2.2.2"
TORCH_INDEX_URL="https://download.pytorch.org/whl/cpu"

# ── Cache Configuration ──────────────────────────────────────────────────
CACHE_DIR=".cache"
PYTEST_CACHE_DIR=".pytest_cache"
